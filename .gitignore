# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local
.claude/
wip/
_backup-pre-quality/

# test output (generated reports, not source code)
tests/reports/**/output/
tests/reports/**/*.html
tests/reports/**/*.json
tests/reports/**/*.txt
tests/reports/**/*.md
# keep test scripts tracked
!tests/reports/**/*.ts
!tests/reports/**/*.mts

.env*.local
